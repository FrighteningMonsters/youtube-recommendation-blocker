{
  "manifest_version": 3,
  "name": "YouTube Recommendation Frequency Blocker",
  "version": "1.0",
  "description": "Hide YouTube videos that appear too often in recommendations.",

  "permissions": [
    "storage"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Recommendation Blocker"
  },

  "host_permissions": [
    "https://www.youtube.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}