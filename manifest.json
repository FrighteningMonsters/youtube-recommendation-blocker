{
  "manifest_version": 3,
  "name": "YouTube Recommendation Frequency Blocker",
  "version": "1.0",
  "description": "Hide YouTube videos that appear too often in recommendations.",

  "permissions": [
    "storage"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Recommendation Blocker"
  },

  "host_permissions": [
    "https://*.youtube.com/*"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-recommendation-blocker@example.com"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
